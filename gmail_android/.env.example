# Gmail Android registration local environment
# Copy to .env and fill only the values you need. Real process environment variables win over .env.

# Appium / Android
APPIUM_SERVER=http://127.0.0.1:4723
APPIUM_SYSTEM_PORT=
AUTO_START_APPIUM=1
ANDROID_ADB_SERVER_PORT=5037
ANDROID_DEVICE=127.0.0.1:5675
ADB_PATH=

# BlueStacks lifecycle
# Fresh runs start/connect the instance, switch Clash node, clear Google/Gmail state,
# then close the instance when the script exits. Use --keep-emulator for manual work.
AUTO_PREPARE_EMULATOR=1
AUTO_SWITCH_NODE=1
AUTO_STOP_EMULATOR=1
KEEP_EMULATOR_ON_MANUAL_HANDOFF=1
BLUESTACKS_INSTANCE=Pie64
BLUESTACKS_ADB_PORT=
BLUESTACKS_HD_PLAYER=C:\Program Files\BlueStacks_nxt\HD-Player.exe
BLUESTACKS_BOOT_WAIT=45
ROTATE_FINGERPRINT=0
ADB_ALLOW_KILL_SERVER=0

# Clash/mihomo node selection
SWITCH_NODE=1
CLASH_API=http://127.0.0.1:9097
CLASH_SECRET=
CLASH_PROXY=http://127.0.0.1:7897
CLASH_GROUP=GLOBAL
NODE_REGION_KEYWORDS=\u7f8e\u56fd,\u65e5\u672c,\u7f8e\u570b,United States,USA,America,Japan,JP
NODE_DELAY_MAX_MS=2000
NODE_SWITCH_MAX_TRY=20
NODE_PROBE_URLS=https://www.google.com/generate_204,https://www.google.com

# Optional account generation
GMAIL_USERNAME_PREFIX=

# Post-registration hardening
# A real second login removes the local Android account, signs in again inside
# BlueStacks, and leaves the account on the Android instance.
SECOND_LOGIN_AFTER_SIGNUP=1
# Second-login reCAPTCHA ("Verify it's you -> I'm not a robot"): auto-solve with the
# vision LLM (common/agent_captcha, same VISION_* keys as GitHub Arkose). Falls back to
# manual handoff on failure or missing keys. RECAPTCHA_SOLVE_ROUNDS = max image-grid rounds.
RECAPTCHA_AUTO_SOLVE=1
RECAPTCHA_SOLVE_ROUNDS=8
# Explicit opt-in: after the second login, try to enable Google 2-Step Verification
# with the same phone lease. Unknown security-page variants stop for manual handoff.
ENABLE_2FA_AFTER_LOGIN=0

# Phone verification mode
# manual: stop at phone verification and let the operator finish it (default).
# auto:   complete phone verification automatically via the firefox.fun SMS
#         provider (hero-sms fallback). Requires the SMS_* values below.
#         Equivalent to passing --auto-phone on the command line.
PHONE_VERIFICATION_MODE=manual

# SMS provider, modeled after reg-factory/common/sms.py.
# Used by PHONE_VERIFICATION_MODE=auto / --auto-phone. firefox.fun is primary
# (SMS_TOKEN + SMS_PROJECT_ID_GMAIL); hero-sms is the fallback.
# Keep secrets in .env or system env only. Do not commit real values.
SMS_API_BASE=http://www.firefox.fun/yhapi.ashx
SMS_TOKEN=
SMS_PROJECT_ID_GMAIL=
SMS_MAXPRICE_GMAIL=20
SMS_COUNTRY_BLACKLIST_GMAIL=261,63

HERO_SMS_API_BASE=https://hero-sms.com/stubs/handler_api.php
HERO_SMS_API_KEY=
HERO_SMS_SERVICE_GMAIL=

# sms-man supports numbers that can receive multiple messages. It is preferred
# when second login or 2FA is enabled so the same number can receive later codes.
SMSMAN_API_BASE=https://api.sms-man.com/control
SMSMAN_TOKEN=
SMSMAN_APP_ID_GMAIL=google
SMSMAN_COUNTRY_GMAIL=0
SMSMAN_MAXPRICE_GMAIL=
SMSMAN_BLACKLIST_GMAIL=

# Consent gates
# Do not enable in unattended runs unless the user/operator has explicitly agreed to the relevant terms.
ACCEPT_TERMS=0
